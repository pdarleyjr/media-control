{
  "name": "@mbfd/console-linux",
  "version": "0.1.0",
  "private": true,
  "description": "Electron kiosk shell for the MBFD Media Control Console.",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "pnpm build:main && pnpm build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "dev": "pnpm build:main && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5174 concurrently -k \"vite --host 127.0.0.1 --port 5174\" \"wait-on http://127.0.0.1:5174 && electron .\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "package:linux": "pnpm build && electron-builder --linux dir"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.mbfd.media-control-console",
    "productName": "MBFD Media Control Console",
    "artifactName": "mbfd-media-control-console-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "linux": {
      "category": "Utility",
      "executableName": "mbfd-media-control-console",
      "target": [
        "dir"
      ]
    }
  }
}
