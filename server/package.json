{
  "name": "media-control-server",
  "version": "1.0.0",
  "description": "Media Control - Digital Signage Management Server",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "dev": "node --watch --env-file-if-exists=.env server.js",
    "test": "npm run test:release",
    "test:node": "node scripts/run-node-tests.mjs",
    "test:ui-contract": "node --test --test-concurrency=1 test/ui-contract/enterprise-api.test.js test/ui-contract/enterprise-i18n.test.js test/ui-contract/error-recovery.test.js test/ui-contract/operator-state.test.js test/ui-contract/operator-store.test.js",
    "test:playwright": "npm --prefix e2e/enterprise-ui test",
    "test:real-app": "npm --prefix e2e/real-app test",
    "test:service-worker": "node e2e/real-app/run-playwright-config.js playwright.service-worker.config.js",
    "test:feature-flag-rollback": "node e2e/real-app/run-playwright-config.js playwright.feature-flag.config.js",
    "test:release": "npm run test:node && npm run test:ui-contract && npm run test:playwright && npm run test:real-app && npm run test:feature-flag-rollback && npm run test:service-worker",
    "test:all": "npm run test:release",
    "topology:report": "node scripts/repair-display-topology.js"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.1",
    "@tus/file-store": "^1.5.0",
    "@tus/server": "^1.10.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "pptxgenjs": "^3.12.0",
    "sharp": "^0.35.3",
    "socket.io": "^4.7.2",
    "stripe": "^20.4.1",
    "unzipper": "^0.12.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "socket.io-client": "^4.8.3"
  }
}
